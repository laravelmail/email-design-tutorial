ountEntityKey":"EgsydW1UYml5SzkyRSDCASgB","factoid":{"factoidRenderer":{"value":{"simpleText":"9,774"},"label":{"simpleText":"Views"},"accessibilityText":"9,774 views","backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4293981695,"raisedBackground":4293981695,"additiveBackground":557544147,"textPrimary":4278523963,"textSecondary":4279911566,"invertedBackground":4279846031,"overlayBackground":3422885947},"darkThemeColorPalette":{"baseBackground":4278258461,"raisedBackground":4278523963,"additiveBackground":725316307,"textPrimary":4292798973,"textSecondary":4288264687,"invertedBackground":4286226917,"overlayBackground":3422885947},"enableColorSampledText":true}},"viewCountType":"VIEW_COUNT_FACTOID_TYPE_TOTAL_VIEWS"}},{"factoidRenderer":{"value":{"simpleText":"2021"},"label":{"simpleText":"13 Dec"},"accessibilityText":"13 Dec 2021","backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4293981695,"raisedBackground":4293981695,"additiveBackground":557544147,"textPrimary":4278523963,"textSecondary":4279911566,"invertedBackground":4279846031,"overlayBackground":3422885947},"darkThemeColorPalette":{"baseBackground":4278258461,"raisedBackground":4278523963,"additiveBackground":725316307,"textPrimary":4292798973,"textSecondary":4288264687,"invertedBackground":4286226917,"overlayBackground":3422885947},"position":"FACTOID_POSITION_LAST","enableColorSampledText":true}}],"channelNavigationEndpoint":{"clickTrackingParams":"CBYQ040EGAUiEwiy2-XA1b2SAxW800IFHR0rBZ7KAQQAeBmu","commandMetadata":{"webCommandMetadata":{"url":"/@unlayer-design","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UC9T7zvaXDtaJLqtv8fjZP2g","canonicalBaseUrl":"/@unlayer-design"}},"channelThumbnail":{"thumbnails":[{"url":"https://yt3.ggpht.com/ytc/AIdro_n7WtxoYiJtIeQn4X0pZ0oSWH3iCPwLqHXHiALnASjjqA=s88-c-k-c0x00ffffff-no-rj"}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"Show more"}},"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"attributedDescriptionBodyText":{"content":"Create captivating email designs with Unlayer efficiently and effortlessly. \n\nUnlayer provides a range of 800+ email templates that are responsive on all devices. Our user-friendly drag and drop editor allows you to create emails from scratch or customize pre-designed templates with great ease. The best part is that designing email templates with Unlayer requires no coding skills at all. \n\nWith Unlayer, you can save custom blocks and tools to use later in the future to save your time. Additionally, you can add merge tags, unsubscribe links, or other special links that are compatible with your email software. After designing, you can export your templates to the best email service providers like Mailchimp, Hubspot, Constant Contact, and others. \n\nOur main goal is to help you create the best-looking emails while saving your time, effort, and money. \n\nStart designing yours for free: https://accounts.unlayer.com/signup?r...\n\nWant to go a step ahead? Try Unlayer Embed. \n\nYou can customize the appearance of your editor, enable or disable features and enhance security with Unlayer’s Embed. Follow our guide to know more about Embed’s additional features. https://docs.unlayer.com/docs/security\n\n\nFollow us on social media: \n\nFacebook:   / unlayer  \n\nLinkedIn: https://www.linkedin.com/company/unla...\n\nTwitter:   / unlayerapp  \n\n#emailbuilder #emaileditor #emailmarketing #emailtemplates #htmlemailtemplates","commandRuns":[{"startIndex":893,"length":40,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBYQ040EGAUiEwiy2-XA1b2SAxW800IFHR0rBZ5I4e6r5OLt5PTaAcoBBAB4Ga4=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbjNTM2l3aThoM2ZWLVRCakVUNFdPa3BWNURwZ3xBQ3Jtc0traz